---
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'div'> {
    /** HTML element to render the panel as (e.g. 'div', 'section', 'article'). */
    as?: 'div' | 'section' | 'article' | 'aside';
}

const { as = 'div', class: className, ...rest } = Astro.props;
const Element = as;
---

<Element class:list={['bg-slate-800/70 backdrop-blur-sm border border-slate-700 rounded-xl', className]} {...rest}>
    <slot />
</Element>
