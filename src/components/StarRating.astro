---
import { clampRating, formatStarRating } from '../lib/ratings';

interface Props {
    rating: number | null;
}

const { rating } = Astro.props;
---

{rating !== null && (
    <div class="flex items-center">
        <span class="bg-blue-500/20 text-blue-400 text-sm px-3 py-1 rounded-full" data-testid="game-rating">
            <span class="text-yellow-400">{formatStarRating(rating)}</span>
            {clampRating(rating).toFixed(1)}
        </span>
    </div>
)}
