---
import Menu from '../assets/icons/menu.svg';
---

<header class="bg-blue-500 dark:bg-blue-700 text-white p-4 shadow-md transition-colors duration-300">
  <div class="container mx-auto flex justify-between items-center pl-4 pr-4">
    <div class="flex items-center">
      <div class="relative group">
        <button id="menu-toggle" class="focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-blue-500 rounded mr-4" aria-label="Toggle menu" aria-expanded="false" aria-controls="menu">
          <Menu class="h-6 w-6" aria-hidden="true" />
        </button>
        <nav id="menu" aria-label="Main" class="hidden absolute left-0 mt-2 w-48 bg-white dark:bg-slate-800 text-slate-800 dark:text-white rounded shadow-lg z-10 transition-colors duration-300">
          <ul class="py-1">
            <li><a href="/" class="block px-4 py-2 hover:bg-slate-100 dark:hover:bg-slate-700">Home</a></li>
            <li><a href="/about" class="block px-4 py-2 hover:bg-slate-100 dark:hover:bg-slate-700">About</a></li>
          </ul>
        </nav>
      </div>
      <div class="text-xl font-bold"><a href="/" class="hover:underline">Tailspin Toys</a></div>
    </div>
  </div>
</header>

<script>
  // Toggle menu visibility when hamburger is clicked
  const menuToggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('menu');
  
  if (menuToggle && menu) {
    menuToggle.addEventListener('click', () => {
      menu.classList.toggle('hidden');
      const isExpanded = !menu.classList.contains('hidden');
      menuToggle.setAttribute('aria-expanded', String(isExpanded));
      if (isExpanded) {
        const firstLink = menu.querySelector('a');
        if (firstLink) firstLink.focus();
      }
    });
    
    // Close menu when clicking outside
    document.addEventListener('click', (event) => {
      const target = event.target;
      const isClickInside = target instanceof Node && (menuToggle.contains(target) || menu.contains(target));
      if (!isClickInside && !menu.classList.contains('hidden')) {
        menu.classList.add('hidden');
        menuToggle.setAttribute('aria-expanded', 'false');
      }
    });

    // Close menu with Escape key and return focus to toggle button
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && !menu.classList.contains('hidden')) {
        menu.classList.add('hidden');
        menuToggle.setAttribute('aria-expanded', 'false');
        menuToggle.focus();
      }
    });
  }
</script>