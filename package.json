{
  "name": "tailspin-toys",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx db/migrate.ts",
    "db:seed": "tsx db/seed.ts",
    "db:setup": "npm run db:migrate && npm run db:seed",
    "predev": "npm run db:setup",
    "prebuild": "npm run db:setup",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "typecheck": "tsgo --noEmit -p tsconfig.tsgo.json",
    "typecheck:astro": "astro sync && astro check",
    "typecheck:all": "npm run typecheck && npm run typecheck:astro",
    "lint": "eslint ."
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@libsql/client": "^0.17.4",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "^7.0.9",
    "drizzle-orm": "^0.45.2",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "autoprefixer": "^10.5.4",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.7.0",
    "eslint-plugin-astro": "^3.0.1",
    "globals": "^17.7.0",
    "postcss": "^8.5.22",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.23.1",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10"
  }
}
